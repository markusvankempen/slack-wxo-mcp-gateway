# Author: Markus van Kempen
# Email: mvankempen@ca.ibm.com | markus.van.kempen@gmail.com
# Web: https://markusvankempen.github.io/
#
# Copy to .env — used via ${VAR} expansion in config.yaml
# Leave SLACK_BOT_TOKEN empty to inherit from ../.env or ../mvk.env
# Do NOT leave the placeholder "xoxb-..." — that causes Slack invalid_auth.

SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

WXO_INSTANCE_URL=
WXO_API_KEY=
WXO_AGENT_ID=1bc5785a-abb7-4ed3-b4d7-7b089650791d

WO_MCSP_TOKEN_URL=https://iam.platform.saas.ibm.com/siusermgr/api/1.0/apikeys/token

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=3100

# MCP transport for IDEs / hosting:
#   streamable-http (default) — /mcp for WxO, Cursor URL, VS Code type:http
#   stdio — Cursor / VS Code / Bob / Antigravity / Claude local mcp.json
#   sse — optional /sse for older SSE clients
# GATEWAY_TRANSPORT=streamable-http
# GATEWAY_ENABLE_POLLER=1   # force poller on in stdio mode (usually leave off)

# Admin dashboard Basic Auth (UI + /api/*). Leave empty for open local/dev.
# /health, /mcp, /slack/events stay public.
GATEWAY_ADMIN_USER=admin
GATEWAY_ADMIN_PASSWORD=change-me
# GATEWAY_REQUIRE_AUTH=true   # fail closed if user/password missing (Code Engine)

# IBM Code Engine deploy (optional)
# CE_PROJECT=my-ce-project
# CE_APP_NAME=slack-wxo-gateway
# IBMCLOUD_API_KEY=
